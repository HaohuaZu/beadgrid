.home-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 14rpx 16rpx calc(env(safe-area-inset-bottom) + 244rpx);
  background:
    radial-gradient(circle at 8% 0%, #fff4f7 0%, transparent 24%),
    radial-gradient(circle at 92% 6%, #eef4ff 0%, transparent 24%),
    #f7f8fa;
}

.top-nav {
  position: sticky;
  top: 0;
  z-index: 40;
  margin: -4rpx -16rpx 0;
  padding: 12rpx 28rpx 12rpx;
  border: none;
  border-radius: 0 0 22rpx 22rpx;
  background: linear-gradient(180deg, #fff4f7 0%, #fff7fa 100%);
  box-shadow: 0 10rpx 24rpx rgba(255, 59, 92, 0.08);
}

.main-nav-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.main-nav-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.main-nav-scroll {
  flex: 1;
  min-width: 0;
}

.main-nav-list {
  display: inline-flex;
  align-items: center;
  gap: 30rpx;
  padding-left: 8rpx;
  padding-right: 8rpx;
}

.main-nav-item {
  position: relative;
  font-size: 38rpx;
  font-weight: 600;
  color: #667085;
  white-space: nowrap;
  line-height: 1.1;
  padding: 8rpx 0;
  z-index: 1;
}

.main-nav-item.is-active {
  color: #1f2430;
  font-weight: 800;
}

.main-nav-item.is-active::before {
  content: "";
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  bottom: 6rpx;
  height: 18rpx;
  border-radius: 6rpx;
  background: #ffd8e5;
  z-index: -1;
}

.search-entry {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 1rpx solid #e6eaf0;
  background: #fff;
  color: #1f2430;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-state {
  margin-top: 10rpx;
  border-radius: 10rpx;
  padding: 8rpx 10rpx;
  font-size: 22rpx;
  background: #ffeef3;
  color: #475467;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.clear-link {
  color: #ff3b5c;
}

.paper-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.paper-card {
  padding: 12rpx;
}

.paper-cover {
  height: 176rpx;
  border-radius: 12rpx 20rpx 12rpx 20rpx;
  padding: 10rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.paper-cover::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      0deg,
      rgba(255, 255, 255, 0.08) 0,
      rgba(255, 255, 255, 0.08) 2rpx,
      transparent 2rpx,
      transparent 14rpx
    ),
    repeating-linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.08) 0,
      rgba(255, 255, 255, 0.08) 2rpx,
      transparent 2rpx,
      transparent 14rpx
    );
  pointer-events: none;
}

.paper-cover-image {
  width: 100%;
  height: 100%;
  border-radius: 10rpx 18rpx 10rpx 18rpx;
  position: relative;
  z-index: 1;
}

.paper-pixel {
  width: 124rpx;
  height: 124rpx;
  border-radius: 8rpx;
  background:
    repeating-linear-gradient(
      0deg,
      rgba(31, 36, 48, 0.08) 0,
      rgba(31, 36, 48, 0.08) 2rpx,
      transparent 2rpx,
      transparent 12rpx
    ),
    repeating-linear-gradient(
      90deg,
      rgba(31, 36, 48, 0.08) 0,
      rgba(31, 36, 48, 0.08) 2rpx,
      transparent 2rpx,
      transparent 12rpx
    ),
    #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.paper-pixel-text {
  font-size: 24rpx;
  color: #344054;
  font-weight: 700;
}

.hot-tag {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #ff3b5c;
}

.tone-orange {
  background: linear-gradient(145deg, #f4f6fb, #e9eef7);
}

.tone-gold {
  background: linear-gradient(145deg, #f2f5ff, #e4ecff);
}

.tone-pink {
  background: linear-gradient(145deg, #ffe8ee, #ffd8e2);
}

.tone-red {
  background: linear-gradient(145deg, #ffe0e8, #ffcfdc);
}

.tone-purple {
  background: linear-gradient(145deg, #ece8ff, #ddd6ff);
}

.paper-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  color: #1f2430;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.paper-author-row {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.author-avatar {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #ffdce5;
  color: #ff3b5c;
  font-size: 18rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.author-name {
  max-width: 150rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #475467;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.paper-size {
  margin-left: auto;
  font-size: 24rpx;
  color: #98a2b3;
}

.paper-meta-row {
  margin-top: 8rpx;
  display: flex;
  gap: 8rpx;
}

.meta-tag {
  font-size: 21rpx;
  color: #667085;
  background: #f2f4f7;
  border-radius: 8rpx;
  padding: 4rpx 10rpx;
  max-width: 150rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.paper-action-row {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 6rpx;
}

.mini-btn {
  min-width: 0;
  height: 46rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  border: 1rpx solid #e6eaf0;
  background: #f8fafc;
  color: #667085;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 46rpx;
  text-align: center;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.metric-btn {
  font-size: 21rpx;
}

.export-btn {
  color: #2563eb;
  border-color: #cfe0ff;
  background: #f4f8ff;
  font-size: 24rpx;
}

.edit-btn {
  color: #ff3b5c;
  border-color: #ffd2dd;
  background: #fff3f6;
  font-size: 22rpx;
}

.bead-btn {
  color: #f97316;
  border-color: #fed7aa;
  background: #fff7ed;
  font-size: 22rpx;
}

.empty-block {
  margin-top: 24rpx;
  text-align: center;
  color: #98a2b3;
  font-size: 22rpx;
}

.generate-btn {
  position: fixed;
  left: 16rpx;
  right: 16rpx;
  bottom: calc(env(safe-area-inset-bottom) + 118rpx);
  height: 86rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ff3b5c, #e53150);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 14rpx 28rpx rgba(229, 49, 80, 0.2);
  letter-spacing: 2rpx;
}

.generate-btn::after {
  border: none;
}

.overlay {
  position: fixed;
  inset: 0;
  z-index: 120;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 160rpx 20rpx 0;
  box-sizing: border-box;
}

.preview-overlay {
  align-items: stretch;
  padding: 28rpx 20rpx calc(env(safe-area-inset-bottom) + 20rpx);
  overflow: hidden;
}

.paper-detail-shell {
  width: 100%;
  max-width: 740rpx;
  height: 100%;
  max-height: calc(100vh - 48rpx);
  box-sizing: border-box;
}

.paper-detail-scroll {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.paper-detail-hero,
.paper-detail-info {
  padding: 18rpx;
}

.paper-detail-hero {
  position: relative;
  overflow: hidden;
  border-radius: 22rpx 28rpx 22rpx 28rpx;
}

.paper-detail-close {
  position: absolute;
  right: 14rpx;
  top: 14rpx;
  z-index: 3;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 1;
  color: #475467;
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.08);
}

.paper-detail-image,
.paper-detail-fallback {
  width: 100%;
  height: 420rpx;
  border-radius: 16rpx 24rpx 16rpx 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.72)),
    repeating-linear-gradient(
      0deg,
      rgba(15, 23, 42, 0.05) 0,
      rgba(15, 23, 42, 0.05) 16rpx,
      transparent 16rpx,
      transparent 32rpx
    ),
    repeating-linear-gradient(
      90deg,
      rgba(15, 23, 42, 0.05) 0,
      rgba(15, 23, 42, 0.05) 16rpx,
      transparent 16rpx,
      transparent 32rpx
    ),
    #fff;
}

.paper-detail-image.is-pixel {
  image-rendering: crisp-edges;
  image-rendering: pixelated;
}

.paper-detail-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}

.paper-detail-info {
  margin-top: 14rpx;
  border-radius: 22rpx 28rpx 22rpx 28rpx;
}

.paper-detail-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.paper-detail-author-wrap {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.paper-detail-avatar-image,
.paper-detail-avatar-text {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.paper-detail-avatar-image {
  display: block;
  border: 3rpx solid #fff;
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.08);
}

.paper-detail-avatar-text {
  background: linear-gradient(135deg, #111827, #6b7280);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.paper-detail-author-copy {
  min-width: 0;
}

.paper-detail-author-label {
  font-size: 20rpx;
  color: #98a2b3;
}

.paper-detail-author-name {
  margin-top: 4rpx;
  font-size: 28rpx;
  color: #1f2430;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.paper-detail-heading {
  margin-top: 18rpx;
}

.paper-detail-label {
  display: block;
  font-size: 20rpx;
  color: #ff5d7d;
  font-weight: 700;
}

.paper-detail-title {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  line-height: 1.18;
  color: #1f2430;
  font-weight: 800;
  word-break: break-all;
}

.paper-detail-date {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #98a2b3;
}

.paper-detail-download {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ffffff, #f3f4f6);
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.paper-detail-download.is-disabled {
  opacity: 0.45;
}

.paper-detail-download-icon {
  font-size: 34rpx;
  color: #475467;
  font-weight: 700;
}

.paper-detail-chip-row {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.paper-detail-chip {
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  background: #f4f6f9;
  color: #667085;
  font-size: 24rpx;
  font-weight: 600;
}

.paper-detail-metric-row {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  align-items: stretch;
}

.paper-detail-metric {
  min-width: 0;
  min-height: 100rpx;
  padding: 14rpx 10rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  border: 1rpx solid #e5e7eb;
  background: #fff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 6rpx;
}

.paper-detail-metric.is-active {
  border-color: #ffc7d3;
  background: #fff4f7;
}

.paper-detail-metric-icon {
  font-size: 34rpx;
  color: #9ca3af;
}

.paper-detail-metric-label {
  font-size: 20rpx;
  color: #98a2b3;
}

.paper-detail-metric.is-active .paper-detail-metric-icon,
.paper-detail-metric.is-active .paper-detail-metric-value,
.paper-detail-metric.is-active .paper-detail-metric-label {
  color: #ff3b5c;
}

.paper-detail-metric-value {
  font-size: 24rpx;
  color: #4b5563;
  font-weight: 700;
  text-align: center;
}

.paper-detail-bead-btn {
  margin-top: 16rpx;
  margin-bottom: calc(env(safe-area-inset-bottom) + 4rpx);
  width: 100%;
  min-height: 112rpx;
  border-radius: 22rpx;
  border: none;
  background: linear-gradient(135deg, #ff6a63, #ff9c2f);
  color: #fff;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 16rpx 28rpx rgba(245, 158, 11, 0.18);
}

.paper-detail-bead-btn::after {
  border: none;
}

.paper-detail-bead-btn.is-disabled {
  background: linear-gradient(135deg, #d1d5db, #9ca3af);
  box-shadow: none;
}

.paper-detail-bead-copy {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
}

.paper-detail-bead-title {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.12;
}

.paper-detail-bead-sub {
  font-size: 20rpx;
  opacity: 0.95;
  text-align: left;
}

.paper-detail-bead-arrow {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
}

.paper-preview-fallback-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.96);
  font-weight: 700;
}

.search-modal {
  width: 100%;
  max-width: 680rpx;
  padding: 18rpx;
}

.search-modal-title {
  font-size: 34rpx;
  color: #1f2430;
  font-weight: 700;
}

.search-modal-row {
  margin-top: 12rpx;
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.search-modal-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e6eaf0;
  padding: 0 16rpx;
  box-sizing: border-box;
  font-size: 22rpx;
}

.search-modal-btn {
  width: 110rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #ff3b5c, #e53150);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
