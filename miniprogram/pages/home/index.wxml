<view class="home-page">
  <view class="top-nav brand-panel">
    <view class="main-nav-row">
      <scroll-view class="main-nav-scroll" scroll-x="true" show-scrollbar="false">
        <view class="main-nav-list">
          <block wx:for="{{mainNavs}}" wx:key="id">
            <view
              class="main-nav-item {{activeMainNav === item.id ? 'is-active' : ''}}"
              data-id="{{item.id}}"
              bindtap="handleMainNavTap"
            >
              {{item.label}}
            </view>
          </block>
        </view>
      </scroll-view>
      <view class="main-nav-actions">
        <view class="search-entry" bindtap="handleOpenSearchPanel">🔍</view>
      </view>
    </view>

    <view class="search-state" wx:if="{{searchKeyword}}">
      <text>关键词：{{searchKeyword}}</text>
      <text class="clear-link" bindtap="handleClearSearch">清除</text>
    </view>
  </view>

  <view class="paper-grid">
    <block wx:for="{{displayPapers}}" wx:key="id">
      <view class="paper-card brand-panel">
        <view class="paper-cover tone-{{item.tone}}" data-id="{{item.id}}" bindtap="handlePreviewPaper">
          <text class="hot-tag" wx:if="{{item.hot || item.isPublishedUserWork}}">{{item.isPublishedUserWork ? '已发布' : '热门'}}</text>
          <image
            wx:if="{{item.previewImage}}"
            class="paper-cover-image"
            src="{{item.previewImage}}"
            mode="aspectFit"
            lazy-load="true"
            data-id="{{item.id}}"
            catchtap="handlePreviewPaper"
          ></image>
          <view wx:else class="paper-pixel" data-id="{{item.id}}" catchtap="handlePreviewPaper">
            <text class="paper-pixel-text">{{item.theme}}</text>
          </view>
        </view>

        <view class="paper-title">{{item.title}}</view>
        <view class="paper-author-row">
          <view class="author-avatar">{{item.avatarText}}</view>
          <text class="author-name">{{item.author}}</text>
          <text class="paper-size">{{item.size}}</text>
        </view>

        <view class="paper-meta-row">
          <text class="meta-tag">{{item.scene}}</text>
          <text class="meta-tag">{{item.difficulty}}</text>
        </view>

        <view class="paper-action-row">
          <view class="mini-btn metric-btn">♡ {{item.likes}}</view>
          <view class="mini-btn metric-btn">☆ {{item.favorites}}</view>
          <view class="mini-btn export-btn" data-id="{{item.id}}" bindtap="handleExportPaper">⬇</view>
          <view
            wx:if="{{item.isPublishedUserWork}}"
            class="mini-btn bead-btn"
            data-id="{{item.id}}"
            bindtap="handleOpenPaperBeadMode"
          >拼豆</view>
          <view wx:else class="mini-btn edit-btn" data-id="{{item.id}}" bindtap="handleEditPaper">✎</view>
        </view>
      </view>
    </block>
  </view>

  <view class="empty-block" wx:if="{{!displayPapers.length}}">
    暂无匹配图纸，试试切换筛选条件
  </view>

  <button class="generate-btn" bindtap="handleGenerate">AI生成图纸</button>

  <view class="overlay preview-overlay" wx:if="{{showPaperPreviewModal}}" bindtap="handleClosePaperPreview">
    <view class="paper-detail-shell" catchtap="noop">
      <scroll-view class="paper-detail-scroll" scroll-y="true" enable-flex="true">
        <view class="paper-detail-hero brand-panel tone-{{previewPaperTone}}">
          <text class="paper-preview-close paper-detail-close" bindtap="handleClosePaperPreview">×</text>
          <image
            wx:if="{{previewPaperImage}}"
            class="paper-detail-image {{previewPaperIsPixel ? 'is-pixel' : ''}}"
            src="{{previewPaperImage}}"
            mode="aspectFit"
            binderror="handlePreviewPaperImageError"
          ></image>
          <view wx:else class="paper-detail-fallback tone-{{previewPaperTone}}">
            <text class="paper-preview-fallback-text">{{previewPaperTitle}}</text>
          </view>
        </view>

        <view class="paper-detail-info brand-panel">
          <view class="paper-detail-topline">
            <view class="paper-detail-author-wrap">
              <image
                wx:if="{{previewPaperAvatarImage}}"
                class="paper-detail-avatar-image"
                src="{{previewPaperAvatarImage}}"
                mode="aspectFill"
              ></image>
              <view wx:else class="paper-detail-avatar-text">{{previewPaperAvatarText}}</view>
              <view class="paper-detail-author-copy">
                <view class="paper-detail-author-label">制作人</view>
                <view class="paper-detail-author-name">{{previewPaperAuthor}}</view>
              </view>
            </view>
            <view
              class="paper-detail-download {{previewPaperCanDownload ? '' : 'is-disabled'}}"
              bindtap="handleDownloadPreviewPaper"
            >
              <text class="paper-detail-download-icon">⇩</text>
            </view>
          </view>

          <view class="paper-detail-heading">
            <text class="paper-detail-label">{{previewPaperLabel}}</text>
            <text class="paper-detail-title">{{previewPaperTitle}}</text>
            <text class="paper-detail-date" wx:if="{{previewPaperDateText}}">{{previewPaperDateText}}</text>
          </view>

          <view class="paper-detail-chip-row">
            <view class="paper-detail-chip">品牌 {{previewPaperBrand}}</view>
            <view class="paper-detail-chip">尺寸 {{previewPaperSize}}</view>
          </view>

          <view class="paper-detail-metric-row">
            <view
              class="paper-detail-metric {{previewPaperLiked ? 'is-active' : ''}}"
              bindtap="handleTogglePaperLike"
            >
              <text class="paper-detail-metric-icon">♡</text>
              <text class="paper-detail-metric-label">点赞</text>
              <text class="paper-detail-metric-value">{{previewPaperLikes}}</text>
            </view>
            <view
              class="paper-detail-metric {{previewPaperFavorited ? 'is-active' : ''}}"
              bindtap="handleTogglePaperFavorite"
            >
              <text class="paper-detail-metric-icon">☆</text>
              <text class="paper-detail-metric-label">收藏</text>
              <text class="paper-detail-metric-value">{{previewPaperFavorites}}</text>
            </view>
            <view
              class="paper-detail-metric paper-detail-metric-download {{previewPaperCanDownload ? '' : 'is-disabled'}}"
              bindtap="handleDownloadPreviewPaper"
            >
              <text class="paper-detail-metric-icon">⇄</text>
              <text class="paper-detail-metric-label">下载</text>
              <text class="paper-detail-metric-value">转为图片</text>
            </view>
          </view>
        </view>

        <button
          class="paper-detail-bead-btn {{previewPaperCanBead ? '' : 'is-disabled'}}"
          data-id="{{previewPaperId}}"
          bindtap="handleOpenPaperBeadMode"
          disabled="{{!previewPaperCanBead}}"
        >
          <view class="paper-detail-bead-copy">
            <text class="paper-detail-bead-title">进入拼豆模式</text>
            <text class="paper-detail-bead-sub">{{previewPaperCanBead ? '使用这张图纸直接开始拼豆，不进入二创编辑' : '当前图纸暂未开放拼豆模式'}}</text>
          </view>
          <text class="paper-detail-bead-arrow">→</text>
        </button>
      </scroll-view>
    </view>
  </view>

  <view class="overlay" wx:if="{{showSearchPanel}}" bindtap="handleCloseSearchPanel">
    <view class="search-modal brand-panel" catchtap="noop">
      <view class="search-modal-title">搜索图纸</view>
      <view class="search-modal-row">
        <input
          class="search-modal-input"
          placeholder="输入图案、场景或作者"
          value="{{searchDraft}}"
          bindinput="handleSearchDraftInput"
          confirm-type="search"
          bindconfirm="handleSearchConfirm"
          focus
        />
        <view class="search-modal-btn" bindtap="handleSearchConfirm">搜索</view>
      </view>
    </view>
  </view>
</view>
